# Скопируйте в файл `.env` в этом каталоге (`cp .env.example .env`) и подставьте свой URL API.
# Docker Compose подставляет переменные из `.env` рядом с compose-файлом.
#
# Публичный HTTP(S) координатора без завершающего «/».
COORDINATOR_URL=http://194.87.98.244:8080

# Период опроса задач и heartbeat (секунды).
HEARTBEAT_SEC=5

# Аргументы после имени образа при `docker run …` (обычно одна команда `map`).
DOCKER_MAP_CMD=map

# Опционально: таймауты docker (секунды), см. deploy/worker/README.md
# REGISTRY_PULL_TIMEOUT_SEC=300
# DOCKER_MAP_TIMEOUT_SEC=300
