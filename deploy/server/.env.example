# Скопируйте в `.env` в этом каталоге. Значения по умолчанию совпадают с `platform/server-api/config/config.json`
# (поле db_clients[].passwd и имя БД). Если меняете пароль здесь — обновите `config.json` и пересоберите образ coordinator.
#
POSTGRES_DB=coordinator_db
POSTGRES_USER=coordinator
POSTGRES_PASSWORD=coordinator
